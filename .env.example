# Copy this file to .env, then add one or more server-side API keys.
# Never put the key in app/static or commit the real .env file.
GROQ_API_KEY=
GEMINI_API_KEY=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
OPENAI_API_KEY=

# Providers are tried from left to right, but only for quota/network/temporary errors.
LEGAL_AGENT_PROVIDER_ORDER=groq,gemini,cloudflare,openai
GROQ_MODEL=openai/gpt-oss-120b
GEMINI_MODEL=gemini-3-flash-preview
CLOUDFLARE_MODEL=@cf/openai/gpt-oss-120b
LEGAL_AGENT_MODEL=gpt-5.4
LEGAL_AGENT_AI_REASONING_EFFORT=low
LEGAL_AGENT_AI_MAX_OUTPUT_TOKENS=1400
LEGAL_AGENT_AI_TIMEOUT=60

LEGAL_AGENT_ENV=pilot
LEGAL_AGENT_AUTH_REQUIRED=true
LEGAL_AGENT_ALLOW_DEMO_SOURCES=false
LEGAL_AGENT_DB=data/legal_agent.db
