# Copy this file to .env, then replace the placeholder with a server-side API key.
# Never put the key in app/static or commit the real .env file.
OPENAI_API_KEY=replace-with-your-api-key
GEMINI_API_KEY=replace-with-your-gemini-api-key

# Strong default for professional legal dialogue. Change it without editing code.
LEGAL_AGENT_PROVIDER=openai
LEGAL_AGENT_MODEL=gpt-5.4
GEMINI_MODEL=gemini-3.5-flash
LEGAL_AGENT_AI_REASONING_EFFORT=low
LEGAL_AGENT_AI_MAX_OUTPUT_TOKENS=1400
LEGAL_AGENT_AI_TIMEOUT=60

LEGAL_AGENT_ENV=pilot
LEGAL_AGENT_AUTH_REQUIRED=true
LEGAL_AGENT_ALLOW_DEMO_SOURCES=false
LEGAL_AGENT_DB=/data/legal_agent.db
